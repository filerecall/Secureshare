# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL - used for redirect URLs and email links.
# Set to http://localhost:3000 locally; to your deployed URL in staging/prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AWS S3 (Milestone 2)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Resend (transactional email)
RESEND_API_KEY=
# Must be on a verified Resend domain. Format: "Display Name <email@domain.com>"
RESEND_FROM_EMAIL=SecureShare <no-reply@filerecall.com>

# Stripe (subscriptions)
# In dev use the test-mode keys (sk_test_..., pk_test_...). Real live keys
# are 107 characters long; anything shorter is invalid or truncated.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# whsec_... value Stripe gives you when you create the webhook endpoint.
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs - created in Stripe Dashboard -> Products. Each plan has
# a monthly and annual price; create all four prices in AUD.
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_ANNUAL=
