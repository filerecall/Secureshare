# Supabase (required for M1)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL - used to build password-reset redirect links.
# Set to http://localhost:3000 locally; to your deployed URL in staging/prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AWS S3 (placeholders - wired up in Milestone 2)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Resend (placeholder - wired up in Milestone 2)
RESEND_API_KEY=
